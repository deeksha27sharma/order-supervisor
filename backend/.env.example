# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_supervisor

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-supervisor

# Groq (free)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MAIN_MODEL=llama-3.3-70b-versatile
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant

# Agent behaviour
# How often the agent wakes up on schedule (in seconds) — default 5 minutes for dev
DEFAULT_WAKEUP_INTERVAL_SECONDS=300
# Max age of a workflow before it is auto-completed (in seconds) — default 7 days
MAX_WORKFLOW_AGE_SECONDS=604800

# App
APP_ENV=development
LOG_LEVEL=INFO